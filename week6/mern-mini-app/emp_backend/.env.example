# Backend Environment Variables

# MongoDB Connection URI
# For local development: mongodb://localhost:27017/emp_backend
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/emp_backend
MONGODB_URI=mongodb://localhost:27017/emp_backend

# Server Port
PORT=5500

# Frontend CORS Origin (where your frontend is deployed)
# For local development: http://localhost:5173
# For production: https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:5173
